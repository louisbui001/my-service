FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY demo/app-v2-buggy.js ./src/app.js
COPY VERSION ./
RUN addgroup -S appgroup && adduser -S appuser -G appgroup && chown -R appuser:appgroup /app
USER appuser
EXPOSE 8080
ENV APP_VERSION=v1.0.2-canary
ENV APP_ENV=production
CMD ["node", "src/app.js"]
